{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "services/**/*.ts",
    "types/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "constants/**/*.ts",
    "tools/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "archive",
    "scripts",
    "dist",
    "public",
    "promo_video",
    "neuro_experiment",
    "App.tsx",
    "cli.ts",
    "index.tsx",
    "vite.config.ts"
  ]
}
