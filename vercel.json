{
  "buildCommand": "node scripts/generate-feed.js && npm run build",
  "outputDirectory": "dist",
  "public": false,
  "rewrites": [
    {
      "source": "/feed.xml",
      "destination": "/feed.xml"
    },
    {
      "source": "/index.html",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
